# ====================================
# LIVE INSTANCE — data is committed
# (Template gitignore overridden for JT's Jarvis fork)
# ====================================

# Sensitive data — never commit
credentials/
costs/

# Local-only overrides
config.local.yaml

# Session/runtime files
*.session
*.lock
*.pid

# ====================================
# KEEP IN GIT (templates & structure)
# ====================================
# .gitkeep files preserved for directory structure
# schema/ - JSON schemas
# hooks/ - webhook handlers (code)
# integrations/ - integration templates
# checklists/ - checklist templates
# workflows/ - workflow definitions
# bookings/ - booking templates
# quotas/ - quota templates
# archived-tasks/ - task archive structure
