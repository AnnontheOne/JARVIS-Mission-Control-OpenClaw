# JARVIS Mission Control .gitignore

# System files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Dependencies
node_modules/
package-lock.json

# Logs — tracked in live instance
!.mission-control/logs/.gitkeep

# Lock files
*.lock

# Temporary files
*.tmp
*.temp

# Sensitive files
.env
.env.*
*.key
*.pem
credentials.json
secrets/

# Build outputs
dist/
build/
out/

# Test coverage
coverage/
.nyc_output/

# Archive (optional - uncomment to exclude)
# .mission-control/archive/

# Backups (local only)
.backups/

# Operational data — commit for live instance tracking
# (Template ignores overridden — JT's Jarvis fork tracks all task/agent data in git)
.mission-control/reports/
.mission-control/archived-tasks/
.mission-control/*.db
.mission-control/*.db-shm
.mission-control/*.db-wal
JARVIS-DEV.md
